export const dynamic = 'force-dynamic';

import { Suspense } from 'react';
import { createClient } from '@/utils/supabase/server';
import { redirect } from 'next/navigation';
import CEOView from '@/components/ceo/CEOView'; // Assuming the view component exists or can be extracted

export default async function CEOPage() {
  const supabase = await createClient();
  const { data: { user } } = await supabase.auth.getUser();

  if (!user) {
    redirect('/login');
  }

  // Double check role
  const { data: profile } = await supabase
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();

  if (profile?.role !== 'CEO') {
    redirect('/unauthorized');
  }

  return (
    <Suspense fallback={<div>Loading CEO Dashboard...</div>}>
      {/* Assuming the rest of the page logic is here */}
      <div className="p-4">
        <h1 className="text-2xl font-bold">CEO Dashboard</h1>
        {/* ... component content ... */}
      </div>
    </Suspense>
  );
}
