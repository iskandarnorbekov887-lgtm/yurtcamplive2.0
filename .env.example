# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-for-admin-api

# Google Calendar Configuration (Optional - for Google Calendar integration)
# Only needed if using Google Calendar instead of internal calendar
# GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key
# GOOGLE_CALENDAR_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CALENDAR_ID=primary-or-your-calendar-id
